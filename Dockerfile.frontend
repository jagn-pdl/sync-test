# Stage 1: builder
FROM node:20-alpine AS builder

WORKDIR /app

COPY src/frontend/package.json /app/package.json
RUN npm ci

COPY src/frontend/ /app/
RUN npm run build

# Stage 2: serve
FROM nginx:alpine

COPY nginx.conf /etc/nginx/nginx.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
